# Prevent caching of index.html so users always get the latest chunk references
/
  Cache-Control: no-cache, no-store, must-revalidate
/index.html
  Cache-Control: no-cache, no-store, must-revalidate

# Allow long-lived caching of hashed assets (they have unique filenames)
/assets/*
  Cache-Control: public, max-age=31536000, immutable
