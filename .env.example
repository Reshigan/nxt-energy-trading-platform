# Environment Variables Configuration

NODE_ENV=development
PORT=3000
MONGODB_URI=mongodb://localhost:27017/nxt_energy_trading

# JWT Configuration
JWT_SECRET=nxt_energy_secret_key_change_in_production
JWT_EXPIRES_IN=24h

# Redis Configuration
REDIS_URL=redis://localhost:6379

# Blockchain Configuration
ETHEREUM_RPC_URL=https://mainnet.infura.io/v3/YOUR_PROJECT_ID
CONTRACT_DEPLOYER_PRIVATE_KEY=YOUR_PRIVATE_KEY

# Email Configuration
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_USER=noreply@nxte.energy
EMAIL_PASS=your_email_password

# API Keys
WEATHER_API_KEY=your_weather_api_key
ENERGY_MARKET_API_KEY=your_energy_market_data_api_key

# Logging
LOG_LEVEL=info

# Performance Settings
TRADE_PROCESSING_TIMEOUT=30000
SIMULATION_BATCH_SIZE=100